;    Version:    V1.10
;    Note:
;        1, CMOD电容需要满足<= 47nf    请特别留意此项！！！！！！！！！！！！！！
;        2, 使能自适应算法时ROM空间增加约250行
;
;             |  Normal Memory(用户可用RAM) | 打开调试输出
;      DPAG0 　|         0x00 ~ 0x3E         | 占用对应的最后四个地址
;###################################################################################################
;    自动自动适应步骤范例：
;           1, #define AUTO_THRESHOLD     打开定义
;           2, 触摸通道设置
;           3, 通过KEY_STATE_H,KEY_STATE_L寄存器获取按键状态
;    手动设置触摸灵敏度步骤范例：
;           1, ;#define AUTO_THRESHOLD    屏蔽定义
;           2, 触摸通道设置
;           3, 触摸阈值设置
;           4, 退出低功耗阈值设置
;           5, 通过KEY_STATE_H,KEY_STATE_L寄存器获取按键状态
;    滑条设置步骤范例：
;           1, 选择自动或手动设置触摸灵敏度，并完成相应设置步骤
;           2, 设置滑条通道数
;           3, 设置滑条通道逻辑起始位置
;           4, 设置滑条级数
;           5, 设置滑条灵敏度
;           6, 通过WHEEL_POSITION寄存器获取滑条位置

#ifndef TOUCH_SET
#define TOUCH_SET
;###################################################################################################
;配置参数
;===================================================================================================
#define OPTION_TOUCH_CHANNEL_SEL_L   11111111B   ;1:TOUCH使能, 0:TOUCH关闭
#define OPTION_TOUCH_CHANNEL_SEL_H   00000000B   ;1:TOUCH使能, 0:TOUCH关闭
;===================================================================================================
;二次触摸(即装配原因触摸线与其它线缠绕一起所造成的超长按键异常)
;#define TOUCH_STATE_TOUCH_AGAIN
;===================================================================================================
;阈值自动适应 (#define AUTO_THRESHOLD 使能此项有效) 推荐使用此模式
;触摸阈值自动适应---此项使能，所使能的触摸通道阈值根据参考阈值等级自动产生，手动阈值定义值将无效
#define AUTO_THRESHOLD                      ;屏蔽此参数为手动设置阈值模式
#define OPTION_TOUCH_REF_GRADE       7      ;参考阈值等级有效值5,6,7; 5灵敏度最高，7灵敏度最低
;===================================================================================================
;手动设置触摸灵敏度 (;#define AUTO_THRESHOLD 屏蔽此条有项)
;阈值定义: 触摸阈值=15< X <250, 噪声阈值 = 触摸阈值*0.2
;TOUCH0
#define OPTION_CFG_CHANNEL_0_0       0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;TOUCH1
#define OPTION_CFG_CHANNEL_1_0       0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;TOUCH2
#define OPTION_CFG_CHANNEL_2_0       0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;TOUCH3
#define OPTION_CFG_CHANNEL_3_0       0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;TOUCH4
#define OPTION_CFG_CHANNEL_4_0       0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;TOUCH5
#define OPTION_CFG_CHANNEL_5_0       0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;TOUCH6
#define OPTION_CFG_CHANNEL_6_0       0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;TOUCH7
#define OPTION_CFG_CHANNEL_7_0       0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;TOUCH8
#define OPTION_CFG_CHANNEL_8_0       0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;TOUCH9
#define OPTION_CFG_CHANNEL_9_0       0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;TOUCH10
#define OPTION_CFG_CHANNEL_10_0      0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;TOUCH11
#define OPTION_CFG_CHANNEL_11_0      0x0620 ;高8位：噪声阈值， 低8位：触摸阈值
;--------------------------------------------------
;匆必留意以下注释，否则容易造成休眠状态退出低功耗模式！！！！！！！！
;  低功耗阈值同时应用于阈值自动适应模式与手动设置阈值模式
;低功耗唤醒使能通道数<=4  设置GP0
;低功耗唤醒使能通道数<=8  设置GP0  GP1
;低功耗唤醒使能通道数<=12 设置GP0  GP1  GP2
;低功耗唤醒使能通道数=1 低功耗唤醒阈值=触摸阈值*70%
;低功耗唤醒使能通道数=2 低功耗唤醒阈值=触摸阈值*30% （选择2个通道中触摸阈值最小值代入运算）
;低功耗唤醒使能通道数=3 低功耗唤醒阈值=触摸阈值*15% （选择3个通道中触摸阈值最小值代入运算）
;低功耗唤醒使能通道数=4 低功耗唤醒阈值=触摸阈值*10% （选择4个通道中触摸阈值最小值代入运算）
;低功耗容易退出，增加低功耗唤醒阈值；低功耗无法唤醒，减少低功耗唤醒阈值
;LP GP0
#define OPTION_LP_GP0_WK             0x04   ;低功耗唤醒阈值0  使能通道数<=4
;LP GP1
#define OPTION_LP_GP1_WK             0x04   ;低功耗唤醒阈值1  使能通道数<=8
;LP GP2
#define OPTION_LP_GP2_WK             0x04   ;低功耗唤醒阈值2  使能通道数<=12
;===================================================================================================
;EMC优化选项，EMC干扰过大时定义此参数可优化EMC干扰
;#define  OPTION_TOUCH_EMC_OPTIMIZE
;===================================================================================================
;CS优化选项
;#define OPT_CS_ENABLE
;===================================================================================================
;滑条、圆环
#define OPTION_TH_WHEEL_NUM          0x00   ;滑条通道数(设置为0-1无滑条，2=3通道，3=4通道……, 滑条最小需要3个通道)
                                            ;如果起始通道+滑条通道数>TOUCH使能通道数，则滑条通道数被强制设置为：
                                            ;TOUCH通道数-起始通道数
#define OPTION_WHEEL_START_POSITION  0x00   ;滑条通道(零点位置)逻辑起始位置
                                            ;例-1:
                                            ;#define OPTION_WHEEL_START_POSITION  0x00
                                            ;OPTION_TOUCH_CHANNEL_SEL_L   00111111B    即TOUCH0(P1.0)为滑条起点
                                            ;例-2:
                                            ;#define OPTION_WHEEL_START_POSITION  0x01
                                            ;OPTION_TOUCH_CHANNEL_SEL_L   00111110B    即TOUCH2(P1.2)为滑条起点
#define OPTION_WHEEL_RESOLUTION      0xFF   ;滑条级数设置(0xFF = 共256级, ,有效值：16~255)
#define OPTION_WHEEL_SWITCH          0x01   ;1=设置为滑条(首尾相连)或圆环，0=为滑条(首尾不相连)。
#define OPTION_WHEEL_THRESHOLD       0x18   ;滑条阈值(值越小灵敏度越高)(有效值：0x10~0xF0)
;===================================================================================================
#endif
;===================================================================================================
